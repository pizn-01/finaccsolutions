# ─────────────────────────────────────────────────────────────────
# FinAccSolutions — Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is NEVER committed to git — it stays on your machine.
# ─────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────
# 1. Go to https://supabase.com → Create a new project
# 2. Go to Project Settings → API
# 3. Copy the values below from the "Project URL" and "anon public" key

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Site URL ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.finaccsolutions.com

# ─────────────────────────────────────────────────────────────────
# SETUP CHECKLIST
# ─────────────────────────────────────────────────────────────────
# After filling in the values above:
#
# 1. Run the database schema:
#    → Go to Supabase Dashboard → SQL Editor → New Query
#    → Copy/paste the contents of supabase/schema.sql and run it
#
# 2. Create your admin user:
#    → Go to Supabase Dashboard → Authentication → Users
#    → Click "Invite User" or "Add User"
#    → Enter your email and set a password
#    → That email/password is your admin login at /admin/login
#
# 3. Install packages:
#    → Run: npm install
#
# 4. Start dev server:
#    → Run: npm run dev
#    → Visit http://localhost:3000/admin/login
# ─────────────────────────────────────────────────────────────────
